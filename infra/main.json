        "[resourceId('Microsoft.Resources/deployments', 'appinsights')]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('containerAppIdentityName'))]",
        "[resourceId('Microsoft.Resources/deployments', 'keyvault')]"
      ]
    }
  ],
  "outputs": {
